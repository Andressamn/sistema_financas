# Conexão com o PostgreSQL
# Em dev (local): postgresql://USER:PASSWORD@localhost:5432/finance_app?schema=public
# Em prod (Neon): cole a connection string da dashboard do Neon (com sslmode=require)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finance_app?schema=public"

# Segredo do JWT
# Gere uma string forte: openssl rand -hex 64
JWT_SECRET="troque-isso-em-producao"

# Porta do servidor (Render define automático em prod)
PORT=3000

# URL do frontend (pra CORS e link de reset de senha)
# Em dev: deixa em branco (CORS aberto)
# Em prod: https://seu-app.vercel.app
FRONTEND_URL=

# Resend (email) — opcional em dev, obrigatório em prod
# Sign up grátis: https://resend.com (3000 emails/mês)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
